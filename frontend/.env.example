# InsForge Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# InsForge Backend Configuration
# ===========================================

# Get this URL after deploying InsForge to Railway/Zeabur/Sealos
# Format: https://your-app-name.railway.app
VITE_INSFORGE_URL=http://localhost:7130

# Optional: API Key for server-to-server communication
VITE_INSFORGE_API_KEY=

# ===========================================
# OpenRAG AI Configuration  
# ===========================================

# Local development (default)
VITE_OPENRAG_URL=http://localhost:3000

# Production (when deployed)
# VITE_OPENRAG_URL=https://openrag.cubiczan.com

# ===========================================
# Optional: Google Maps API
# For location-based pricing
# ===========================================

VITE_GOOGLE_MAPS_API_KEY=

# ===========================================
# Feature Flags
# ===========================================

# Enable/disable features
VITE_ENABLE_AI_SUGGESTIONS=true
VITE_ENABLE_PDF_EXPORT=true
VITE_ENABLE_FILE_UPLOADS=true